# Copy to .env for local Docker Compose usage (docker-compose.yml reads it automatically).

# Absolute path on your host machine to the markdown vault to serve — e.g. this
# Foam vault. Bind-mounted read-write into the container (writes land here).
VAULT_PATH=/absolute/path/to/your/vault

# Git sync (P1) — both optional. Without GIT_REMOTE_URL, writes still commit locally
# to VAULT_PATH (git init'd automatically), just never pushed — local-only
# self-hosting without GitHub. To push, use an HTTPS remote with an embedded token,
# e.g. https://x-access-token:<PAT>@github.com/<owner>/<repo>.git
# Also set these in Coolify's environment UI when using docker-compose.coolify.yml.
# GIT_REMOTE_URL=
# GIT_BRANCH=main

# Postgres — not consumed by the app yet (auth/workspaces land in P2), included so the
# local stack already matches the target self-hosting shape (app + Postgres, same
# Docker image locally or on a public server — see the PRD).
POSTGRES_USER=fluffmind
POSTGRES_PASSWORD=fluffmind
POSTGRES_DB=fluffmind
