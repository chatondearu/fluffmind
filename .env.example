# Copy to .env for local Docker Compose usage (docker-compose.yml reads it automatically).

# Absolute path on your host machine to the markdown vault to serve — e.g. this
# Foam vault. Bind-mounted read-write into the container (writes land here).
VAULT_PATH=/absolute/path/to/your/vault

# Git sync (P1) — both optional. Without GIT_REMOTE_URL, writes still commit locally
# to VAULT_PATH (git init'd automatically), just never pushed — local-only
# self-hosting without GitHub. To push, use an HTTPS remote with an embedded token,
# e.g. https://x-access-token:<PAT>@github.com/<owner>/<repo>.git
# Also set these in Coolify's environment UI when using docker-compose.coolify.yml.
# GIT_REMOTE_URL=
# GIT_BRANCH=main
# GITHUB_WEBHOOK_SECRET=   # HMAC secret for POST /api/webhooks/github (push events)

# Auth/workspaces (P2) — optional until auth is enabled.
# AUTH_DISABLED=true keeps P1 behavior even when DATABASE_URL is set (Coolify default).
AUTH_DISABLED=true
# When enabling auth on Coolify, also set BETTER_AUTH_SECRET (32+ random bytes) and
# BETTER_AUTH_URL to your public URL (e.g. https://fluffmind.example.com).
# WORKSPACES_ROOT is used when auth is enabled (one directory per workspace).
WORKSPACES_ROOT=/data/workspaces
# BETTER_AUTH_SECRET should be a random 32+ bytes value in production.
BETTER_AUTH_SECRET=
# Public URL used by Better Auth callbacks.
BETTER_AUTH_URL=http://localhost:3000
# GitHub OAuth app credentials (required for GitHub login when auth is enabled).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MCP (P5) — local stdio bridge uses VAULT_PATH (see README § MCP).
# MCP_WORKSPACE_ID=default

# Postgres — required when auth is enabled (`AUTH_DISABLED=false`).
# Also used for P7a distributed workspace locks when set (even if AUTH_DISABLED=true).
POSTGRES_USER=fluffmind
POSTGRES_PASSWORD=fluffmind
POSTGRES_DB=fluffmind
# DATABASE_URL=postgres://fluffmind:fluffmind@localhost:5432/fluffmind

# Workspace lock wait (P7a) — max ms to wait for Postgres advisory / file lock before 503.
# LOCK_WAIT_MS=45000
